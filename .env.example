# =============================================================================
# ZeroDev Smart Routing Address POC — Environment Variables
# =============================================================================
# Copy this file: cp .env.example .env
# Then fill in the values below.
# =============================================================================

# Your wallet address (e.g. from MetaMask).
# This is a PUBLIC address (0x...), NOT a private key.
# It is set as the "owner" of the Smart Routing Address — meaning this wallet
# is authorized to call getWithdrawTokensCalls() to recover stuck funds.
# Bridged funds land in this same wallet on the destination chain.
OWNER_ADDRESS=0xYourWalletAddressHere

# -----------------------------------------------------------------------------
# Optional: ZeroDev Project ID
# -----------------------------------------------------------------------------
# Only needed if you want to SPONSOR FEES so depositors receive 100% of their
# deposit (instead of paying the 0.20% ZeroDev routing fee themselves).
# Get one free at: https://dashboard.zerodev.app
# Leave commented out for standard (non-sponsored) mode.
# ZERODEV_PROJECT_ID=your-project-id-here
